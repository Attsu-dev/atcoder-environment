    "ダイクストラ": {
        "prefix": "dijkstra",
        "body": [
            "VLL Dijkstra(const vector<vector<pair<int, ll>>>& G, int s) {",
            "  int N = G.size();",
            "  VLL dist(N, INF);",
            "",
            "  priority_queue<pair<ll, int>, vector<pair<ll, int>>, greater<pair<ll, int>>>",
            "      pq;",
            "",
            "  dist[s] = 0;",
            "  pq.emplace(0, s);",
            "",
            "  while (!pq.empty()) {",
            "    auto [d, v] = pq.top();",
            "    pq.pop();",
            "",
            "    if (d != dist[v]) continue;",
            "",
            "    for (auto [to, cost] : G[v]) {",
            "      if (chmin(dist[to], d + cost)) {",
            "        pq.emplace(dist[to], to);",
            "      }",
            "    }",
            "  }",
            "",
            "  return dist;",
            "}"
        ],
        "description": "ダイクストラ"
    },
    "幅優先探索": {
        "prefix": "bfs",
        "body": [
            "queue<int> q;",
            "vector<int> dist(N, -1);",
            "",
            "dist[s] = 0;",
            "q.push(s);",
            "",
            "while (!q.empty()) {",
            "    int v = q.front();",
            "    q.pop();",
            "",
            "    for (int to : G[v]) {",
            "        if (dist[to] != -1) continue;",
            "",
            "        dist[to] = dist[v] + 1;",
            "        q.push(to);",
            "    }",
            "}"
        ],
        "description": "幅優先探索"
    },
