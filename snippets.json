    "桁和関数": {
        "prefix": "ketawa",
        "body": [
            "ll ketawa(ll x) {",
            "  string s = to_string(x);",
            "  ll res = 0;",
            "  for (char c : s) res += c - '0';",
            "  return res;",
            "}"
        ],
        "description": "整数xを10進数表記したときの各桁の和を返す"
    },
    "エラトステネスの篩": {
        "prefix": "eratos",
        "body": [
            "VLL Eratosthenes(const ll N) {",
            "  VB is_prime(N + 1, true);",
            "  VLL P;",
            "  for (int i = 2; i <= N; i++) {",
            "    if (is_prime[i]) {",
            "      for (int j = 2 * i; j <= N; j += i) is_prime[j] = false;",
            "      P.emplace_back(i);",
            "    }",
            "  }",
            "  return P;",
            "}"
        ],
        "description": "エラトステネスの篩"
    }
}