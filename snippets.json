    "桁和関数": {
        "prefix": "ketawa",
        "body": [
            "ll ketawa(ll x) {",
            "  string s = to_string(x);",
            "  ll res = 0;",
            "  for (char c : s) res += c - '0';",
            "  return res;",
            "}"
        ],
