    "組み合せを前計算": {
        "prefix": "ncr",
        "body": [
            "const int MAX = 510000;",
            "mint fac[MAX], finv[MAX], inv[MAX];",
            "",
            "// COMを使うための前処理",
            "void ncrInit() {",
            "  const int MOD = mint::mod();",
            "  fac[0] = fac[1] = 1;",
            "  finv[0] = finv[1] = 1;",
            "  inv[1] = 1;",
            "  for (int i = 2; i < MAX; i++) {",
            "    fac[i] = fac[i - 1] * i;",
            "    inv[i] = MOD - inv[MOD % i] * (MOD / i);",
            "    finv[i] = finv[i - 1] * inv[i];",
            "  }",
            "}",
            "",
            "mint ncr(int n, int r) {",
            "  if (n < r) return 0;",
            "  if (n < 0 || r < 0) return 0;",
            "  return fac[n] * finv[r] * finv[n - r];",
            "}",
            "",
            "// solve()でncrInit();を呼ぶのを忘れない",
            "",
            ""
        ],
        "description": "組み合せを前計算"
    }
