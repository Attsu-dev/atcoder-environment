    "幅優先探索": {
        "prefix": "bfs",
        "body": [
            "auto BFS = [&](const VVLL& G, int s) {",
            "  ll n = G.size();",
            "  VLL dist(n, -1);",
            "  queue<ll> q;",
            "",
            "  dist[s] = 0;",
            "  q.push(s);",
            "",
            "  while (!q.empty()) {",
            "    ll v = q.front();",
            "    q.pop();",
            "",
            "    for (ll to : G[v]) {",
            "      if (dist[to] != -1) continue;",
            "",
            "      dist[to] = dist[v] + 1;",
            "      q.push(to);",
            "    }",
            "  }",
            "",
            "  return dist;",
            "};",
            ""
        ],
        "description": "幅優先探索"
    },
    "グリッド幅優先探索": {
        "prefix": "grid_bfs",
        "body": [
            "auto GridBFS = [&](const VS& S, PLL s) {",
            "  ll h = S.size();",
            "  ll w = S[0].size();",
            "  VVLL dist(h, VLL(w, -1));",
            "  queue<PLL> q;",
            "",
            "  auto inside = [&](ll i, ll j) {",
            "    return 0 <= i && i < h && 0 <= j && j < w;",
            "  };",
            "",
            "  dist[s.first][s.second] = 0;",
            "  q.emplace(s);",
            "",
            "  while (!q.empty()) {",
            "    auto [i, j] = q.front();",
            "    q.pop();",
            "",
            "    rep(dir, 4) {",
            "      ll ni = i + dx[dir];",
            "      ll nj = j + dy[dir];",
            "      if (!inside(ni, nj)) continue;",
            "      if (S[ni][nj] == '#') continue;",
            "      if (dist[ni][nj] != -1) continue;",
            "",
            "      dist[ni][nj] = dist[i][j] + 1;",
            "      q.emplace(ni, nj);",
            "    }",
            "  }",
            "",
            "  return dist;",
            "};",
            ""
        ],
        "description": "グリッド幅優先探索"
    },
