    "エラトステネスの篩": {
        "prefix": "eratos",
        "body": [
            "VLL Eratosthenes(const ll N) {",
            "  VB is_prime(N + 1, true);",
            "  VLL P;",
            "  for (int i = 2; i <= N; i++) {",
            "    if (is_prime[i]) {",
            "      for (int j = 2 * i; j <= N; j += i) is_prime[j] = false;",
            "      P.emplace_back(i);",
            "    }",
            "  }",
            "  return P;",
            "}"
        ],
        "description": "エラトステネスの篩"
    },
    "進数変換": {
        "prefix": "shinsuu",
        "body": [
            "// n進数をm進数に変換する",
            "string ntom(string S, ll n, ll m) {",
            "  ll sum = stoll(S, nullptr, n);",
            "  string res = \"\";",
            "  do {",
            "    ll num = sum % m;",
            "    res = static_cast<char>(num + '0') + res;",
            "    sum /= m;",
            "  } while (sum);",
            "  return res;",
            "}"
        ],
        "description": "進数変換"
    },
    "座標圧縮": {
        "prefix": "Compress",
        "body": [
            "// 座標圧縮",
            "template <class T>",
            "struct Compress {",
            "  vector<T> v;",
            "",
            "  Compress(const vector<T>& V) : v(V) {",
            "    sort(v.begin(), v.end());",
            "    v.erase(unique(v.begin(), v.end()), v.end());",
            "  }",
            "",
            "  int size() const { return v.size(); }",
            "",
            "  int to(const T& x) const {",
            "    return lower_bound(v.begin(), v.end(), x) - v.begin();",
            "  }",
            "",
            "  T from(int x) const { return v[x]; }",
            "};",
            ""
        ],
        "description": "座標圧縮"
