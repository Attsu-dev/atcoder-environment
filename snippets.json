    "ダイクストラ": {
        "prefix": "dijkstra",
        "body": [
            "auto Dijkstra = [&](const VVPLL& G, int s) {",
            "  ll n = G.size();",
            "  VLL dist(n, INF);",
            "  priority_queue<PLL, vector<PLL>, greater<PLL>> pq;",
            "",
            "  dist[s] = 0;",
            "  pq.emplace(0, s);",
            "",
            "  while (!pq.empty()) {",
            "    auto [d, v] = pq.top();",
            "    pq.pop();",
            "    if (d != dist[v]) continue;",
            "",
            "    for (auto [to, cost] : G[v]) {",
            "      if (chmin(dist[to], d + cost)) {",
            "        pq.emplace(dist[to], to);",
            "      }",
            "    }",
            "  }",
            "",
            "  return dist;",
            "};",
            ""
        ],
        "description": "ダイクストラ"
    },
    "グリッドダイクストラ": {
        "prefix": "grid_dijkstra",
        "body": [
            "auto GridDijkstra = [&](const VVLL& C, PLL s) {",
            "  ll h = C.size();",
            "  ll w = C[0].size();",
            "  VVLL dist(h, VLL(w, INF));",
            "  priority_queue<array<ll, 3>, vector<array<ll, 3>>, greater<array<ll, 3>>> pq;",
            "",
            "  auto inside = [&](ll i, ll j) {",
            "    return 0 <= i && i < h && 0 <= j && j < w;",
            "  };",
            "",
            "  dist[s.first][s.second] = 0;",
            "  pq.push({0, s.first, s.second});",
            "",
            "  while (!pq.empty()) {",
            "    auto [d, i, j] = pq.top();",
            "    pq.pop();",
            "    if (d != dist[i][j]) continue;",
            "",
            "    rep(dir, 4) {",
            "      ll ni = i + dx[dir];",
            "      ll nj = j + dy[dir];",
            "      if (!inside(ni, nj)) continue;",
            "      if (C[ni][nj] == INF) continue;",
            "",
            "      if (chmin(dist[ni][nj], d + C[ni][nj])) {",
            "        pq.push({dist[ni][nj], ni, nj});",
            "      }",
            "    }",
            "  }",
            "",
            "  return dist;",
            "};",
            ""
        ],
        "description": "グリッドダイクストラ"
    }
}
