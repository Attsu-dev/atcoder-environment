    "ナップサックDP": {
        "prefix": "knapsack",
        "body": [
            "ll Knapsack(vector<ll>& w, vector<ll>& v, int W) {",
            "  int N = w.size();",
            "",
            "  vector<ll> dp(W + 1);",
            "",
            "  for (int i = 0; i < N; i++) {",
            "    for (int j = W; j >= w[i]; j--) {",
            "      chmax(dp[j], dp[j - w[i]] + v[i]);",
            "    }",
            "  }",
            "",
            "  return *max_element(dp.begin(), dp.end());",
            "}"
        ],
        "description": "ナップサックDP"
    }
