    "めぐる式二分探索": {
        "prefix": "meguru",
        "body": [
            "auto isOK = [&](ll X) -> bool {",
            "",
            "};",
            "",
            "ll ok = 1;",
            "ll ng = INF;",
            "",
            "while (abs(ok - ng) > 1) {",
            "  ll mid = (ok + ng) / 2;",
            "  if (isOK(mid))",
            "    ok = mid;",
            "  else",
            "    ng = mid;",
            "}",
            "",
            "print(ok);"
        ],
        "description": "めぐる式二分探索"
    },
    "幅優先探索": {
        "prefix": "bfs",
        "body": [
            "queue<int> q;",
            "vector<int> dist(N, -1);",
            "",
            "dist[s] = 0;",
            "q.push(s);",
            "",
            "while (!q.empty()) {",
            "    int v = q.front();",
            "    q.pop();",
            "",
            "    for (int to : G[v]) {",
            "        if (dist[to] != -1) continue;",
            "",
            "        dist[to] = dist[v] + 1;",
            "        q.push(to);",
            "    }",
            "}"
        ],
        "description": "幅優先探索"
    },
